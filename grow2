Message("Loaded", "zhou's No-Stun Aura Loaded!", 3)

-- ==================== 瞬間互動 (Fast Interact) ====================
-- 使用 task.spawn 讓它在背景執行，不影響主程式運作
task.spawn(function()
    -- 遍歷遊戲中目前已存在的所有物件
    for _, item in pairs(game:GetDescendants()) do
        if item:IsA("ProximityPrompt") then
            item.HoldDuration = 0
        end
    end

    -- 監聽未來新生成的物件 (例如地圖刷新、新掉落物)
    game.DescendantAdded:Connect(function(item)
        if item:IsA("ProximityPrompt") then
            item.HoldDuration = 0
        end
    end)
    
    Message("Fast Interact", "ProximityPrompt Bypass Active", 3)
end)
